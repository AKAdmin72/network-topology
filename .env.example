# SNMP community string
SNMP_COMMUNITY=public

# Aruba OSCX REST API credentials (leave empty if not using Aruba switches)
ARUBA_REST_USER=
ARUBA_REST_PASS=

# Path to directory containing SSL certificate files:
#   server.crt  — certificate (or fullchain)
#   server.key  — private key
# Referenced in nginx.conf as /etc/nginx/certs/server.crt and server.key
CERT_DIR=./cert
